From 1d8a40ca4d95ed99e47af72ca7fd7046ab06b24c Mon Sep 17 00:00:00 2001
From: Jose Tiburcio Ribeiro Netto <jnetto@mineiro.io>
Date: Wed Mar 4 18:20:57 2026 -0300
Subject: [PATCH] fix(fish): preserve generated script and exit status in init wrapper

diff --git a/src/commands.c b/src/commands.c
index 4c9092a..b2dc8f1 100644
--- a/src/commands.c
+++ b/src/commands.c
@@ -391,9 +391,14 @@ void cmd_init(int argc, char **argv, const char *tries_path) {
     // Fish shell version
     printf(
       "function try\n"
-      "  set -l out (%s exec --path %s $argv 2>/dev/tty)\n"
-      "  or begin; echo $out; return $status; end\n"
-      "  eval $out\n"
+      "  set -l out (%s exec --path %s $argv 2>/dev/tty | string collect)\n"
+      "  set -l rc $pipestatus[1]\n"
+      "  if test $rc -eq 0\n"
+      "    eval $out\n"
+      "  else\n"
+      "    echo $out\n"
+      "    return $rc\n"
+      "  end\n"
       "end\n",
       zstr_cstr(&escaped_self), zstr_cstr(&escaped_tries));
   } else {
