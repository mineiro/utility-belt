+#[cfg(target_os = "linux")]
+fn resolve_system_ort_library() -> Option<PathBuf> {
+    let mut search_dirs = Vec::new();
+
+    if let Some(libdir) = option_env!("RAPIDRAW_SYSTEM_ORT_LIBDIR") {
+        search_dirs.push(PathBuf::from(libdir));
+    }
+
+    search_dirs.push(PathBuf::from("/usr/lib64"));
+    search_dirs.push(PathBuf::from("/usr/lib"));
+
+    for dir in search_dirs {
+        for candidate in ["libonnxruntime.so", "libonnxruntime.so.1"] {
+            let path = dir.join(candidate);
+            if path.exists() {
+                return Some(path);
+            }
+        }
+
+        let Ok(entries) = fs::read_dir(&dir) else {
+            continue;
+        };
+
+        let mut matches: Vec<PathBuf> = entries
+            .filter_map(Result::ok)
+            .map(|entry| entry.path())
+            .filter(|path| {
+                path.file_name()
+                    .and_then(|name| name.to_str())
+                    .map_or(false, |name| name.starts_with("libonnxruntime.so."))
+            })
+            .collect();
+        matches.sort();
+        if let Some(path) = matches.pop() {
+            return Some(path);
+        }
+    }
+
+    None
+}
+
 fn main() {
     tauri::Builder::default()
         .plugin(tauri_plugin_single_instance::init(|app, argv, _cwd| {
